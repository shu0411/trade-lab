AWS_DEFAULT_REGION=ap-northeast-1
TABLE_NAME=trade-lab-hypotheses
IMAGES_BUCKET=trade-lab-charts-local

# ストアバックエンド選択: sqlite（デフォルト）または dynamodb
# STORE_BACKEND=dynamodb

# SQLiteのDBファイルパス（STORE_BACKEND=sqlite 時）
# SQLITE_DB_PATH=trade_lab.db

# LocalStack（STORE_BACKEND=dynamodb のローカル開発時）
# AWS_ENDPOINT_URL=http://localhost:4566
# AWS_ACCESS_KEY_ID=test
# AWS_SECRET_ACCESS_KEY=test

# 本番AWSに接続する場合は STORE_BACKEND=dynamodb を設定し、
# ~/.aws/credentials または環境変数で実際の認証情報を設定する

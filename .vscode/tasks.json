{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "LocalStack: 起動",
      "type": "shell",
      "command": "docker compose up -d",
      "options": { "cwd": "${workspaceFolder}/backend/docker" },
      "group": "build",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "LocalStack: 停止",
      "type": "shell",
      "command": "docker compose down",
      "options": { "cwd": "${workspaceFolder}/backend/docker" },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "LocalStack: テーブル・バケット作成",
      "type": "shell",
      "command": "AWS_ACCESS_KEY_ID=test AWS_SECRET_ACCESS_KEY=test bash ${workspaceFolder}/backend/scripts/setup-localstack.sh",
      "dependsOn": "LocalStack: 起動",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "LocalStack: セットアップ完了まで待機してリソース作成",
      "type": "shell",
      "command": "until curl -s http://localhost:4566/_localstack/health | grep -q '\"dynamodb\": \"running\"\\|\"dynamodb\": \"available\"'; do sleep 1; done && AWS_ACCESS_KEY_ID=test AWS_SECRET_ACCESS_KEY=test bash ${workspaceFolder}/backend/scripts/setup-localstack.sh",
      "dependsOn": "LocalStack: 起動",
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    },
    {
      "label": "Backend: サーバー起動 (SQLite)",
      "type": "shell",
      "command": "source .venv/bin/activate && uvicorn app.main:app --reload --port 8000",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "servers" },
      "problemMatcher": [
        {
          "pattern": [{ "regexp": ".", "file": 1, "location": 2, "message": 3 }],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*Started reloader process.*",
            "endsPattern": ".*Application startup complete.*"
          }
        }
      ]
    },
    {
      "label": "Backend: サーバー起動 (LocalStack)",
      "type": "shell",
      "command": "source .venv/bin/activate && set -a && source .env && set +a && uvicorn app.main:app --reload --port 8000",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "servers" },
      "problemMatcher": [
        {
          "pattern": [{ "regexp": ".", "file": 1, "location": 2, "message": 3 }],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*Started reloader process.*",
            "endsPattern": ".*Application startup complete.*"
          }
        }
      ]
    },
    {
      "label": "Frontend: 起動",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/frontend" },
      "isBackground": true,
      "presentation": { "reveal": "always", "panel": "dedicated", "group": "servers" },
      "problemMatcher": [
        {
          "pattern": [{ "regexp": ".", "file": 1, "location": 2, "message": 3 }],
          "background": {
            "activeOnStart": true,
            "beginsPattern": ".*VITE.*",
            "endsPattern": ".*ready in.*"
          }
        }
      ]
    },
    {
      "label": "テスト: 全て実行",
      "type": "shell",
      "command": "source .venv/bin/activate && python -m pytest tests/ -v",
      "options": { "cwd": "${workspaceFolder}/backend" },
      "group": { "kind": "test", "isDefault": true },
      "presentation": { "reveal": "always", "panel": "shared" },
      "problemMatcher": []
    }
  ]
}
